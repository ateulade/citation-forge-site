# Citation Forge marketing site — environment variables
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit secrets.
#
# All client-side vars must be prefixed with PUBLIC_.

# Site URL — full URL with scheme. Used by sitemap + canonical + RSS.
PUBLIC_SITE_URL=https://citationforge.com

# ── Phase 2: Free-audit form ───────────────────────────────────────────
# Transactional email
RESEND_API_KEY=

# Real Citation Forge SaaS API (Phase 2/4). Stub returned until set.
PRODUCT_API_URL=https://api.citationforge.com
PRODUCT_API_KEY=

# ── GitHub Actions secrets (set in repo Settings → Secrets, not here) ──
# CLOUDFLARE_API_TOKEN — Cloudflare API token w/ Pages:Edit
# CLOUDFLARE_ACCOUNT_ID — 32-char hex from Cloudflare dashboard
# INDEXNOW_KEY — 32-char hex; also drop public/<KEY>.txt for ownership proof
# GITHUB_TOKEN_FOR_PRODUCT_PUSH — PAT for Citation Forge SaaS to push pages (Phase 4)
